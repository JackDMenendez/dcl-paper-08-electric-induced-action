# Default to automatic line-ending normalisation.
* text=auto

# Always-text files (LF in the repo, native on checkout).
*.tex text
*.md text
*.txt text
*.py text
*.sh text
*.cmd text
*.bib text
*.json text
*.yml text
*.yaml text
*.cff text

# Always-CRLF on checkout.
*.sln text eol=crlf

# Truly binary -- never normalise.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.swf binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.eot binary
*.woff binary
*.pyc binary
*.pdf binary
*.npy binary
